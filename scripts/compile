#!/bin/bash

SDK_PATH=$(xcrun --sdk iphoneos --show-sdk-path)
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd -P)
REPO_ROOT="${SCRIPT_DIR}/.."

compile_file() {
	set -e
	local FILE="$1"

	if [ ! -f "$FILE" ]; then
		echo "Error: $FILE not found"
		exit 1
	fi

	FILE_NO_SUFFIX="${FILE%.*}"
	FILE_EXTENSION="${FILE##*.}"
	NAME=$(basename "$FILE_NO_SUFFIX")
	FILE_DOTENV="${FILE_NO_SUFFIX}.env"
	
	if [ "$FILE_EXTENSION" == "m" ]; then
		COMPILER="clang"
	elif [ "$FILE_EXTENSION" == "mm" ]; then
		COMPILER="clang++"
	elif [ "$FILE_EXTENSION" == "dylib" ]; then
		echo "Error: $FILE is already a dylib. Skipping compilation."
		return 0
	else
		echo "Error: Unsupported file extension for $FILE"
		exit 1
	fi

	if [ -f "$FILE_DOTENV" ]; then eval "$(cat $FILE_DOTENV)"; fi
	EXTRA_FLAGS=${EXTRA_FLAGS:-""}
	EXTRA_FLAGS="$EXTRA_FLAGS $EXTRA_FLAGS_ARGS"
	OUTPUT_DIR=${OUTPUT_DIR:-"$REPO_ROOT/build"}
	OUTPUT_PATH=${OUTPUT_PATH:-""}
	CLANG_LINKS=${CLANG_LINKS:-""}
	CLANG_INCLUDES=${CLANG_INCLUDES:-"$REPO_ROOT/lib $REPO_ROOT/lib/fishhook $REPO_ROOT/lib/utils"}
	CLANG_SOURCES=${CLANG_SOURCES:-"$REPO_ROOT/lib/fishhook/fishhook.c"}
	CLANG_FRAMEWORKS=${CLANG_FRAMEWORKS:-"CoreAudio AVFoundation CoreMedia CoreVideo AudioToolbox UIKit Foundation"}
	CLANG_INCLUDES="$CLANG_INCLUDES $CLANG_EXTRA_INCLUDES"
	CLANG_SOURCES="$CLANG_SOURCES $CLANG_EXTRA_SOURCES"
	CLANG_FRAMEWORKS="$CLANG_FRAMEWORKS $CLANG_EXTRA_FRAMEWORKS"
	CLANG_LINKS="$CLANG_LINKS $CLANG_EXTRA_LINKS"
	echo "Clang extra links: $CLANG_EXTRA_LINKS"

	if [ -z "$OUTPUT_PATH" ]; then
		OUTPUT_PATH="$OUTPUT_DIR/$NAME.dylib"
	fi

	FLAGS=("-dynamiclib" "-arch" "arm64" "-isysroot" "$SDK_PATH")

	# 2. Append includes (properly quoted)
	for INCLUDE in $CLANG_INCLUDES; do
		FLAGS+=("-I" "$INCLUDE")
	done

	# 3. Append frameworks
	for FRAMEWORK in $CLANG_FRAMEWORKS; do
		FLAGS+=("-framework" "$FRAMEWORK")
	done

	# 4. Append links
	for LIB in $CLANG_LINKS; do
		FLAGS+=("-l$LIB")
	done

	# 5. Add the parts you specifically asked about
	# Note: if EXTRA_FLAGS contains multiple flags in one string, 
	# we let it split, but we quote the path-based variables.
	FLAGS+=($EXTRA_FLAGS) 
	FLAGS+=("-o" "$OUTPUT_PATH")
	FLAGS+=("$FILE")

	# Add non-C sources first, then C sources last (with -x c) so -x none is never needed
	C_SOURCES=()
	for SRC in $CLANG_SOURCES; do
		if [[ "$COMPILER" == "clang++" && "$SRC" == *.c ]]; then
			C_SOURCES+=("$SRC")
		else
			FLAGS+=("$SRC")
		fi
	done
	if [[ ${#C_SOURCES[@]} -gt 0 ]]; then
		FLAGS+=("-x" "c" "${C_SOURCES[@]}")
	fi

	mkdir -p "$OUTPUT_DIR"

	# 6. Execute using the special array expansion symbol "${ARRAY[@]}"
	echo "Running: $COMPILER ${FLAGS[@]}"
	"$COMPILER" "${FLAGS[@]}"
	echo "Successfully compiled $FILE to $OUTPUT_PATH"
}

PASSED=()
FAILED=()

for FILE in "$@"; do
    echo "----------------------------------------"
    
    # 1. Run in a subshell SEPARATELY from the 'if' statement
    # This allows 'set -e' to actually work.
    ( set -e; compile_file "$FILE" )
    
    # 2. Capture the exit status of the subshell
    STATUS=$?

    # 3. Use the status to update your tracking arrays
    if [ $STATUS -eq 0 ]; then
        PASSED+=("$FILE")
    else
        FAILED+=("$FILE")
    fi
done

# --- THE SUMMARY ---
echo -e "\n========================================"
echo "          COMPILATION SUMMARY"
echo "========================================"
echo "Total processed: $(($#))"
echo "Successfully compiled: ${#PASSED[@]}"
echo "Failed to compile:     ${#FAILED[@]}"

if [ ${#FAILED[@]} -ne 0 ]; then
    echo -e "\nFailed Files:"
    for F in "${FAILED[@]}"; do
        echo "  - $F"
    done
    exit 1 # Exit script with error if any file failed
fi

echo -e "\nAll files compiled successfully! 🎉"
